        <activity
            android:name="org.aohp.agentdriver.ui.uda.UdaAppActivity"
            android:documentLaunchMode="intoExisting"
            android:exported="true"
            android:taskAffinity="org.aohp.agentdriver.uda"
            android:label="@string/uda_custom_app"
            android:theme="@style/Theme.AohpAgentDriver.UdaFullscreen">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:host="app"
                    android:scheme="aohp-uda" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="org.aohp.agentdriver.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_bridge_paths" />
        </provider>

        <service
            android:name=".executor.ws.AohpJsonRpcService"
            android:foregroundServiceType="dataSync"
            tools:ignore="ForegroundServicePermission" />

        <service android:name=".executor.MyAccessibilityService"
            android:enabled="true"
            android:label="@string/accessibility_service_label"
            android:description="@string/accessibility_service_description"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <meta-data android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
        </service>

        <service
            android:name=".executor.RecordService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="mediaProjection" />

        <service
            android:name=".uda.UdaGenerationService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            tools:ignore="ForegroundServicePermission" />

        <receiver
            android:name=".overlay.TapHighlightReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="org.aohp.agentdriver.action.TAP_HIGHLIGHT_SHOW" />
                <action android:name="org.aohp.agentdriver.action.TAP_HIGHLIGHT_HIDE" />
            </intent-filter>
        </receiver>

    </application>

    <queries>
        <!-- 声明需要访问的应用类型 -->
        <!-- 可以启动的应用 -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

</manifest>