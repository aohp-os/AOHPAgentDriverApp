    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.MANAGE_AOHP_VIRTUAL_DISPLAY"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.MANAGE_AOHP_ADS"
        tools:ignore="ProtectedPermissions" />
    <!-- Quick Search / 自动化：前台注入按键（与 platform 签名一致时授予） -->
    <uses-permission android:name="android.permission.INJECT_EVENTS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />

    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:ignore="ProtectedPermissions" />

    <!-- Privileged system image: allow enabling our accessibility service without manual Settings UI -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:name=".MyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AohpAgentDriver"
        tools:targetApi="31"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">
        <activity
            android:label="@string/app_name"
            android:exported='true'
            android:name="org.aohp.agentdriver.MainActivity"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="org.aohp.agentdriver.ui.filebridge.FileBridgeActivity"
            android:exported="true"
            android:label="File Bridge"
            android:theme="@style/Theme.AohpAgentDriver" />

        <activity
            android:name="org.aohp.agentdriver.ui.filebridge.FileBridgeShareActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:label="File Bridge Share"
            android:theme="@style/Theme.AohpAgentDriver" />

        <activity
            android:name="org.aohp.agentdriver.ui.uda.UdaPreviewActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:label="@string/uda_preview"
            android:theme="@style/Theme.AohpAgentDriver.UdaFullscreen" />

        <activity
            android:name="org.aohp.agentdriver.ui.uda.UdaDemoLauncherActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:noHistory="true"
            android:taskAffinity="org.aohp.agentdriver.uda"
            android:theme="@style/Theme.AohpAgentDriver" />

        <activity-alias
            android:name="org.aohp.agentdriver.ui.uda.UdaDemoGiftPickerLauncher"
            android:enabled="false"
            android:excludeFromRecents="true"
            android:exported="true"
            android:icon="@drawable/uda_ic_demo_gift_fg"
            android:label="Gift Picker"
            android:noHistory="true"
            android:roundIcon="@drawable/uda_ic_demo_gift_fg"
            android:targetActivity="org.aohp.agentdriver.ui.uda.UdaDemoLauncherActivity"
            android:taskAffinity="org.aohp.agentdriver.uda"
            android:theme="@style/Theme.AohpAgentDriver">
            <meta-data
                android:name="org.aohp.agentdriver.UDA_DEMO_JOB_ID"
                android:value="demo-gift-picker" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name="org.aohp.agentdriver.ui.uda.UdaDemoPythonLearningLauncher"
