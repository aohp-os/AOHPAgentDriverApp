<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sandbox_service_id_hint"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_service_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:hint="demo-loop" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/sandbox_service_cmd_hint"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/et_service_command"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:fontFamily="monospace"
        android:hint="while true; do date; sleep 10; done" />
</LinearLayout>
