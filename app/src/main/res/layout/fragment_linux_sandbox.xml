<?xml version="1.0" encoding="utf-8"?>
<!-- Scrollable: small screens (720x1280) cannot fit header + services + terminal + IME in one viewport. -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:clipToPadding="false"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="8dp">

        <!-- Header: title, actions, env list, service status -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sandbox_title"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E" />

                        <TextView
                            android:id="@+id/tv_service_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="11sp"
                            android:textColor="#666666"
                            android:text="@string/sandbox_checking_container" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cli_contact_test"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="6dp"
                        android:text="@string/sandbox_cli_contact_test"
                        android:textSize="10sp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_create_env"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/sandbox_new_env"
                        android:textSize="11sp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        app:cornerRadius="8dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconSize="16dp"
                        app:iconPadding="4dp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_env_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:minHeight="@dimen/sandbox_env_list_min_height"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sandbox_background_services"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_start_openclaw_gateway"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="6dp"
                        android:text="OpenClaw Gateway"
                        android:textSize="10sp"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_start_service"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/sandbox_start_service"
                        android:textSize="11sp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_services"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="ifContentScrolls" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Terminal: fixed height; inner scroll for long output -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="@dimen/sandbox_terminal_height"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#1E1E2E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="6dp"
                    android:background="#181825">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@android:color/holo_red_light"
                        android:layout_marginEnd="4dp" />
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@android:color/holo_orange_light"
                        android:layout_marginEnd="4dp" />
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@android:color/holo_green_light"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_terminal_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/terminal_title_default"
                        android:textColor="#CDD6F4"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_export_terminal"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/sandbox_export_log"
                        android:textColor="#89B4FA"
                        android:textSize="11sp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_terminal"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="@string/sandbox_clear_screen"
                        android:textColor="#CDD6F4"
                        android:textSize="11sp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="8dp" />
                </LinearLayout>

                <org.aohp.agentdriver.ui.sandbox.TerminalScrollView
                    android:id="@+id/sv_terminal"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fillViewport="true"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false"
                    android:scrollbarStyle="outsideOverlay">

                    <TextView
                        android:id="@+id/tv_terminal_output"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:textColor="#A6E3A1"
                        android:lineSpacingExtra="2dp"
                        android:textIsSelectable="false"
                        android:text="@string/sandbox_welcome" />
                </org.aohp.agentdriver.ui.sandbox.TerminalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#A6E3A1"
                    android:fontFamily="monospace"
                    android:paddingStart="10dp"
                    android:paddingEnd="6dp" />

                <EditText
                    android:id="@+id/et_command_input"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/sandbox_command_hint"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:inputType="text"
                    android:imeOptions="actionSend"
                    android:singleLine="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_command"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/sandbox_send"
                    android:textSize="12sp"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
