<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="false"
    android:focusable="false"
    app:cardBackgroundColor="@color/overlay_panel_bg"
    app:cardCornerRadius="16dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:orientation="vertical"
        android:paddingStart="@dimen/overlay_panel_padding"
        android:paddingEnd="@dimen/overlay_panel_padding"
        android:paddingBottom="@dimen/overlay_panel_padding_bottom"
        android:paddingTop="@dimen/overlay_panel_padding_top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/app_name"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_overlay_app_icon" />

            <TextView
                android:id="@+id/tv_overlay_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/overlay_title"
                android:textColor="@color/overlay_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_overlay_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/overlay_state_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_overlay_task_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="@dimen/overlay_task_section_weight"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/overlay_task_label"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_overlay_task"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:layout_weight="1"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/overlay_text_primary"
                android:textSize="13sp"
                app:autoSizeMaxTextSize="13sp"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/overlay_divider" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_overlay_events"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="@dimen/overlay_events_weight"
            android:clipToPadding="true"
            android:clickable="false"
            android:focusable="false"
            android:nestedScrollingEnabled="true"
            android:overScrollMode="never"
            android:paddingBottom="@dimen/overlay_events_padding_bottom"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/tv_overlay_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
